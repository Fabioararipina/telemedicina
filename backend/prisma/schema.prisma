generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  cpf             String         @unique
  phone           String?
  passwordHash    String
  lsxToken        String?        // Token gerado pela API da LSX (Meditele patient ID)
  asaasCustomerId String?        // ID do cliente na Asaas
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subscriptions   Subscription[]
  coupons         CouponUse[]
}

model Plan {
  id            String         @id @default(uuid())
  name          String         // Ex: Individual Promocional
  price         Decimal        @db.Decimal(10, 2)
  type          String         // INDIVIDUAL, FAMILIAR, AVULSO, CORTESIA
  description   String?        // Descrição curta exibida na LP
  mediteleId    String?        // UUID do plano correspondente na Meditele
  active        Boolean        @default(true)
  // Landing page
  showOnLp      Boolean        @default(false)  // exibir na landing page
  featured      Boolean        @default(false)  // tag "Mais escolhido"
  originalPrice Decimal?       @db.Decimal(10, 2) // preço riscado "Normal R$X"
  features      String?        // JSON: ["Clínico 24h", "1 especialista/mês"]
  ctaLabel      String?        // texto do botão CTA, ex: "Quero o Individual"
  periodLabel   String?        // "/mês" ou "30 dias"
  sortOrder     Int            @default(0)      // ordem na LP
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                  String     @id @default(uuid())
  userId              String
  user                User       @relation(fields: [userId], references: [id])
  planId              String
  plan                Plan       @relation(fields: [planId], references: [id])
  status              String     // ACTIVE, CANCELLED, PENDING, SUSPENDED
  startDate           DateTime   @default(now())
  endDate             DateTime?
  asaasSubscriptionId String?    // ID da assinatura/pagamento na Asaas
  soldById            String?    // Vendedor que realizou a venda
  soldBy              Employee?  @relation(fields: [soldById], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Employee {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  passwordHash     String
  role             String         @default("VENDEDOR") // ADMIN, SUPERVISOR, VENDEDOR
  active           Boolean        @default(true)
  termsAcceptedAt  DateTime?      // null = não aceitou o termo ainda
  termsAcceptedIp  String?        // IP no momento da aceitação
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  subscriptions    Subscription[]
}

model Partner {
  id          String       @id @default(uuid())
  name        String       // Nome da Farmácia / Laboratório
  type        String       // PHARMACY, LABORATORY
  contact     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  commissions Commission[]
  coupons     Coupon[]
}

model Coupon {
  id           String      @id @default(uuid())
  code         String      @unique // Ex: DESC10
  discountDesc String      // Ex: "10% de desconto"
  partnerId    String
  partner      Partner     @relation(fields: [partnerId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  usages       CouponUse[]
}

model CouponUse {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  couponId     String
  coupon       Coupon       @relation(fields: [couponId], references: [id])
  usedAt       DateTime     @default(now())
  purchaseValue Decimal?    @db.Decimal(10, 2) // Valor total gasto no parceiro
  commission   Commission?
}

model Commission {
  id          String    @id @default(uuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id])
  couponUseId String    @unique
  couponUse   CouponUse @relation(fields: [couponUseId], references: [id])
  amount      Decimal   @db.Decimal(10, 2)
  status      String    // PENDING, PAID
  createdAt   DateTime  @default(now())
  paidAt      DateTime?
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  plan      String   // INDIVIDUAL, FAMILIAR, AVULSO
  createdAt DateTime @default(now())
}

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}